{
	"name": "@withxat/eslint-config",
	"type": "module",
	"version": "1.1.2",
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"description": "🧃 Xat's ESLint config preset / Xat 自用强迫症 ESLint 配置",
	"author": "Xat <i@xat.sh> (https://xat.sh)",
	"license": "MIT",
	"homepage": "https://github.com/withxat/eslint-config",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/withxat/eslint-config.git"
	},
	"bugs": {
		"url": "https://github.com/withxat/eslint-config/issues"
	},
	"keywords": [
		"eslint",
		"eslint-config"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "nr gen && tsdown --clean --dts",
		"stub": "tsdown",
		"dev": "npx @eslint/config-inspector --config eslint.config.ts",
		"build:inspector": "pnpm build && npx @eslint/config-inspector build",
		"watch": "tsdown --watch",
		"lint": "eslint",
		"gen": "tsx src/scripts/typegen.ts",
		"prepack": "nr build",
		"release": "bumpp && pnpm publish",
		"test": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"eslint": "^10"
	},
	"dependencies": {
		"@e18e/eslint-plugin": "^0.3.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
		"@eslint-react/eslint-plugin": "^4.2.3",
		"@eslint/markdown": "^8.0.1",
		"@limegrass/eslint-plugin-import-alias": "^1.6.1",
		"@next/eslint-plugin-next": "^16.2.3",
		"@prettier/plugin-xml": "^3.4.2",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"@vitest/eslint-plugin": "^1.6.15",
		"astro-eslint-parser": "^1.4.0",
		"eslint-config-flat-gitignore": "^2.3.0",
		"eslint-flat-config-utils": "^3.1.0",
		"eslint-merge-processors": "^2.0.0",
		"eslint-plugin-antfu": "^3.2.2",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-command": "^3.5.2",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-import-lite": "^0.6.0",
		"eslint-plugin-jsdoc": "^62.9.0",
		"eslint-plugin-jsonc": "^3.1.2",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-no-only-tests": "^3.3.0",
		"eslint-plugin-perfectionist": "^5.8.0",
		"eslint-plugin-pnpm": "^1.6.0",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-svelte": "^3.17.0",
		"eslint-plugin-toml": "^1.3.1",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"eslint-plugin-yml": "^3.3.1",
		"globals": "^17.4.0",
		"jsonc-eslint-parser": "^3.1.0",
		"local-pkg": "^1.1.2",
		"parse-gitignore": "^2.0.0",
		"svelte-eslint-parser": "^1.6.0",
		"toml-eslint-parser": "^1.0.3",
		"yaml-eslint-parser": "^2.0.0"
	},
	"devDependencies": {
		"@antfu/ni": "^30.0.0",
		"@eslint/config-inspector": "^1.5.0",
		"@types/node": "^25.6.0",
		"@withxat/eslint-config": "workspace:*",
		"@withxat/tsconfig": "^1.0.4",
		"astro": "^6.1.5",
		"bumpp": "^11.0.1",
		"eslint": "^10.2.0",
		"eslint-typegen": "^2.3.1",
		"jiti": "^2.6.1",
		"lefthook": "^2.1.5",
		"next": "^16.2.3",
		"react": "^19.2.5",
		"svelte": "^5.55.2",
		"tsdown": "^0.21.7",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
