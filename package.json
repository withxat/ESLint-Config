{
	"name": "@xats/eslint-config",
	"type": "module",
	"version": "2.1.2",
	"packageManager": "pnpm@10.6.2+sha512.47870716bea1572b53df34ad8647b42962bc790ce2bf4562ba0f643237d7302a3d6a8ecef9e4bdfc01d23af1969aa90485d4cebb0b9638fa5ef1daef656f6c1b",
	"description": "",
	"author": "Xat <i@xat.sh> (https://xat.sh)",
	"license": "MIT",
	"keywords": [
		"eslint",
		"eslint-config"
	],
	"exports": {
		".": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "nlx @eslint/config-inspector --config eslint.config.js",
		"prepare": "lefthook install && nr build",
		"release": "bumpp && npm publish",
		"build": "nr type:gen && tsup --clean --dts",
		"type:gen": "tsx scripts/typegen.ts",
		"type:check": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"peerDependencies": {
		"eslint": "^9.5.0"
	},
	"dependencies": {
		"@eslint-react/eslint-plugin": "^1.34.1",
		"@html-eslint/eslint-plugin": "^0.35.2",
		"@html-eslint/parser": "^0.35.2",
		"@stylistic/eslint-plugin": "^4.2.0",
		"@typescript-eslint/eslint-plugin": "^8.26.1",
		"@typescript-eslint/parser": "^8.26.1",
		"eslint-config-flat-gitignore": "^2.1.0",
		"eslint-flat-config-utils": "^2.0.1",
		"eslint-merge-processors": "^2.0.0",
		"eslint-plugin-html": "^8.1.2",
		"eslint-plugin-import-x": "^4.8.0",
		"eslint-plugin-jsdoc": "^50.6.6",
		"eslint-plugin-jsonc": "^2.19.1",
		"eslint-plugin-n": "^17.16.2",
		"eslint-plugin-perfectionist": "^4.10.1",
		"eslint-plugin-react-hooks": "5.2.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"eslint-plugin-regexp": "^2.7.0",
		"eslint-plugin-toml": "^0.12.0",
		"eslint-plugin-unicorn": "^57.0.0",
		"eslint-plugin-unused-imports": "^4.1.4",
		"eslint-plugin-yml": "^1.17.0",
		"eslint-typegen": "^2.1.0",
		"globals": "^16.0.0",
		"jsonc-eslint-parser": "^2.4.0",
		"local-pkg": "^1.1.1",
		"toml-eslint-parser": "^0.10.0",
		"yaml-eslint-parser": "^1.3.0"
	},
	"devDependencies": {
		"@antfu/ni": "^24.2.0",
		"@types/node": "^22.13.10",
		"bumpp": "^10.1.0",
		"eslint": "^9.22.0",
		"lefthook": "^1.11.3",
		"react": "^19.0.0",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lefthook"
		]
	}
