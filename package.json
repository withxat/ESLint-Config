{
	"name": "@withxat/eslint-config",
	"type": "module",
	"version": "1.1.5",
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"description": "🧃 Xat's ESLint config preset / Xat 自用强迫症 ESLint 配置",
	"author": "Xat <i@xat.sh> (https://xat.sh)",
	"license": "MIT",
	"homepage": "https://github.com/withxat/eslint-config",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/withxat/eslint-config.git"
	},
	"bugs": {
		"url": "https://github.com/withxat/eslint-config/issues"
	},
	"keywords": [
		"eslint",
		"eslint-config"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "nr gen && tsdown --clean --dts",
		"stub": "tsdown",
		"dev": "npx @eslint/config-inspector --config eslint.config.ts",
		"build:inspector": "pnpm build && npx @eslint/config-inspector build",
		"watch": "tsdown --watch",
		"lint": "eslint",
		"gen": "tsx src/scripts/typegen.ts",
		"prepack": "nr build",
		"release": "bumpp && pnpm publish",
		"test": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"eslint": "^10"
	},
	"dependencies": {
		"@e18e/eslint-plugin": "^0.5.1",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@eslint-react/eslint-plugin": "^5.10.0",
		"@eslint/markdown": "^8.0.2",
		"@limegrass/eslint-plugin-import-alias": "^1.6.1",
		"@next/eslint-plugin-next": "^16.2.9",
		"@prettier/plugin-xml": "^3.4.2",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@typescript-eslint/eslint-plugin": "^8.62.1",
		"@typescript-eslint/parser": "^8.62.1",
		"@vitest/eslint-plugin": "^1.6.20",
		"astro-eslint-parser": "^2.1.0",
		"eslint-config-flat-gitignore": "^2.3.0",
		"eslint-flat-config-utils": "^3.2.0",
		"eslint-merge-processors": "^2.0.0",
		"eslint-plugin-antfu": "^3.2.3",
		"eslint-plugin-astro": "^2.1.1",
		"eslint-plugin-better-tailwindcss": "^4.6.0",
		"eslint-plugin-command": "^3.5.2",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-import-lite": "^0.6.0",
		"eslint-plugin-jsdoc": "^63.0.10",
		"eslint-plugin-jsonc": "^3.2.0",
		"eslint-plugin-n": "^18.2.1",
		"eslint-plugin-no-only-tests": "^3.4.0",
		"eslint-plugin-perfectionist": "^5.9.1",
		"eslint-plugin-pnpm": "^1.6.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"eslint-plugin-regexp": "^3.1.1",
		"eslint-plugin-svelte": "^3.20.0",
		"eslint-plugin-toml": "^1.4.0",
		"eslint-plugin-unicorn": "^69.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"eslint-plugin-yml": "^3.5.0",
		"find-up-simple": "^1.0.1",
		"globals": "^17.7.0",
		"jsonc-eslint-parser": "^3.1.0",
		"local-pkg": "^1.2.1",
		"parse-gitignore": "^2.0.0",
		"svelte-eslint-parser": "^1.8.0",
		"toml-eslint-parser": "^1.0.3",
		"yaml-eslint-parser": "^2.0.0"
	},
	"devDependencies": {
		"@antfu/ni": "^30.2.0",
		"@eslint/config-inspector": "^3.0.4",
		"@types/node": "^26.0.1",
		"@withxat/eslint-config": "workspace:*",
		"@withxat/tsconfig": "^1.0.4",
		"astro": "^7.0.3",
		"bumpp": "^11.1.0",
		"eslint": "^10.6.0",
		"eslint-typegen": "^2.3.1",
		"jiti": "^2.7.0",
		"lefthook": "^2.1.9",
		"next": "^16.2.9",
		"react": "^19.2.7",
		"svelte": "^5.56.4",
		"tailwindcss": "^4.3.2",
		"tsdown": "^0.22.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
