{
	"name": "@xats/eslint-config",
	"type": "module",
	"version": "2.0.3",
	"packageManager": "pnpm@10.2.1+sha512.398035c7bd696d0ba0b10a688ed558285329d27ea994804a52bad9167d8e3a72bcb993f9699585d3ca25779ac64949ef422757a6c31102c12ab932e5cbe5cc92",
	"description": "",
	"author": "Xat <i@xat.sh> (https://xat.sh)",
	"license": "MIT",
	"keywords": [
		"eslint",
		"eslint-config"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "nlx @eslint/config-inspector --config eslint.config.js",
		"prepare": "lefthook install && nr build",
		"release": "bumpp && npm publish",
		"build": "nr type:gen && tsup --format esm,cjs --clean --dts",
		"type:gen": "tsx scripts/typegen.ts",
		"type:check": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"peerDependencies": {
		"eslint": "^9.5.0"
	},
	"dependencies": {
		"@eslint-react/eslint-plugin": "^1.26.2",
		"@html-eslint/eslint-plugin": "^0.34.0",
		"@html-eslint/parser": "^0.34.0",
		"@stylistic/eslint-plugin": "^3.1.0",
		"@typescript-eslint/eslint-plugin": "^8.23.0",
		"@typescript-eslint/parser": "^8.23.0",
		"eslint-config-flat-gitignore": "^2.0.0",
		"eslint-flat-config-utils": "^2.0.1",
		"eslint-merge-processors": "^2.0.0",
		"eslint-plugin-html": "^8.1.2",
		"eslint-plugin-import-x": "^4.6.1",
		"eslint-plugin-jsdoc": "^50.6.3",
		"eslint-plugin-jsonc": "^2.19.1",
		"eslint-plugin-n": "^17.15.1",
		"eslint-plugin-perfectionist": "^4.8.0",
		"eslint-plugin-react-hooks": "5.1.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"eslint-plugin-regexp": "^2.7.0",
		"eslint-plugin-tailwindcss": "^3.18.0",
		"eslint-plugin-toml": "^0.12.0",
		"eslint-plugin-unicorn": "^56.0.1",
		"eslint-plugin-unused-imports": "^4.1.4",
		"eslint-plugin-yml": "^1.16.0",
		"eslint-typegen": "^1.0.0",
		"globals": "^15.14.0",
		"jsonc-eslint-parser": "^2.4.0",
		"local-pkg": "^1.0.0",
		"toml-eslint-parser": "^0.10.0",
		"yaml-eslint-parser": "^1.2.3"
	},
	"devDependencies": {
		"@antfu/ni": "^23.3.1",
		"@types/node": "^22.13.1",
		"bumpp": "^10.0.2",
		"eslint": "^9.20.0",
		"lefthook": "^1.10.10",
		"react": "^19.0.0",
		"tailwindcss": "^3.4.17",
		"tsup": "^8.3.6",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3"
	},
	"overrides": {
		"tailwindcss": ">=3.4.0"
	}
}
