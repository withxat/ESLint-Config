{
	"name": "@withxat/eslint-config",
	"type": "module",
	"version": "1.0.5",
	"packageManager": "pnpm@10.28.2",
	"description": "🧃 Xat's ESLint config preset / Xat 自用强迫症 ESLint 配置",
	"author": "Xat <i@xat.sh> (https://xat.sh)",
	"license": "MIT",
	"homepage": "https://github.com/withxat/eslint-config",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/withxat/eslint-config.git"
	},
	"bugs": {
		"url": "https://github.com/withxat/eslint-config/issues"
	},
	"keywords": [
		"eslint",
		"eslint-config"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "nr gen && tsdown --clean --dts",
		"stub": "tsdown",
		"dev": "npx @eslint/config-inspector --config eslint.config.ts",
		"build:inspector": "pnpm build && npx @eslint/config-inspector build",
		"watch": "tsdown --watch",
		"lint": "eslint",
		"gen": "tsx scripts/typegen.ts",
		"prepack": "nr build",
		"release": "bumpp && pnpm publish",
		"test": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"eslint": "^9.10.0 || ^10.0.0"
	},
	"dependencies": {
		"@e18e/eslint-plugin": "^0.2.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
		"@eslint-react/eslint-plugin": "^2.13.0",
		"@eslint/markdown": "^7.5.1",
		"@limegrass/eslint-plugin-import-alias": "^1.6.0",
		"@next/eslint-plugin-next": "^16.1.6",
		"@prettier/plugin-xml": "^3.4.2",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@vitest/eslint-plugin": "^1.6.10",
		"astro-eslint-parser": "^1.3.0",
		"eslint-config-flat-gitignore": "^2.2.1",
		"eslint-flat-config-utils": "^3.0.2",
		"eslint-merge-processors": "^2.0.0",
		"eslint-plugin-antfu": "^3.2.2",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-command": "^3.5.2",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-import-lite": "^0.5.2",
		"eslint-plugin-jsdoc": "^62.7.1",
		"eslint-plugin-jsonc": "^3.1.1",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-no-only-tests": "^3.3.0",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-pnpm": "^1.6.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-toml": "^1.3.1",
		"eslint-plugin-unicorn": "^63.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"eslint-plugin-yml": "^3.3.1",
		"globals": "^17.4.0",
		"jsonc-eslint-parser": "^3.1.0",
		"local-pkg": "^1.1.2",
		"parse-gitignore": "^2.0.0",
		"toml-eslint-parser": "^1.0.3",
		"yaml-eslint-parser": "^2.0.0"
	},
	"devDependencies": {
		"@antfu/ni": "^28.3.0",
		"@eslint/config-inspector": "^1.5.0",
		"@types/node": "^25.4.0",
		"@withxat/eslint-config": "workspace:*",
		"@withxat/tsconfig": "^1.0.0",
		"astro": "^6.0.2",
		"bumpp": "^10.4.1",
		"eslint": "^10.0.3",
		"eslint-typegen": "^2.3.1",
		"jiti": "^2.6.1",
		"lefthook": "^2.1.3",
		"react": "^19.2.4",
		"tsdown": "^0.21.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
